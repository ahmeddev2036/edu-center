# ─── Environment ──────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# للتشغيل المحلي (بدون Docker):
# POSTGRES_URL=postgres://postgres:postgres@localhost:5432/edu_center
# للتشغيل بـ Docker:
POSTGRES_URL=postgres://postgres:postgres@db:5432/edu_center

# ─── Redis ────────────────────────────────────────────────────────────────────
# للتشغيل المحلي:
# REDIS_URL=redis://localhost:6379
# للتشغيل بـ Docker:
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# غيّر هذا في الإنتاج إلى قيمة عشوائية طويلة
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── Notifications (اختياري) ──────────────────────────────────────────────────
WHATSAPP_WEBHOOK_URL=
EMAIL_WEBHOOK_URL=
SMS_WEBHOOK_URL=
NOTIFY_API_KEY=

# ─── OpenAI (اختياري) ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Stripe (اختياري) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Cloudinary (اختياري) ─────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Admin Seed ───────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@edu.com
ADMIN_PASSWORD=Admin@123
